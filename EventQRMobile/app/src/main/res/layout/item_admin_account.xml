<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_admin_surface_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/textAccountAvatar"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_circle_purple_soft"
        android:gravity="center"
        android:text="A"
        android:textColor="#4F46E5"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textAccountName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Juan dela Cruz"
            android:textColor="#111827"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textAccountEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="juan@email.com"
            android:textColor="#6B7280"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textAccountRoleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_role_badge_purple"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="Attendee"
            android:textColor="#4338CA"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textAccountStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_admin_status_active_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:text="Active"
            android:textColor="#065F46"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
