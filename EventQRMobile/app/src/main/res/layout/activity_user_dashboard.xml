<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="171dp"
        android:background="@drawable/bg_eventqr_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="17dp"
        android:paddingTop="27dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtDashboardWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back!"
                    android:textColor="#FFFFFF"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDashboardRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="Attendee"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="top|end">

                <ImageView
                    android:id="@+id/btnDashboardNotifications"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_gravity="center"
                    android:contentDescription="Notifications"
                    android:src="@drawable/notification_bell"
                    android:tint="#FFFFFF" />

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="3dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_circle_blue" />
            </FrameLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="59dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTotalRegistrations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Registrations"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTotalEvents"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Events"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTotalRewards"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Points"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="17dp"
                android:paddingTop="30dp"
                android:paddingBottom="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="286dp"
                    android:background="@drawable/bg_card"
                    android:elevation="6dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingTop="22dp"
                    android:paddingBottom="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Actions"
                        android:textColor="#000000"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnAttendeeHub"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_quick_action_button"
                            android:drawableTop="@drawable/ic_action_search"
                            android:drawablePadding="9dp"
                            android:drawableTint="#000000"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minHeight="0dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:text="Browse Events"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnStaffHub"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="30dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_quick_action_button"
                            android:drawableTop="@drawable/ic_nav_calendar"
                            android:drawablePadding="9dp"
                            android:drawableTint="#000000"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minHeight="0dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:text="My Events"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="84dp"
                        android:layout_marginTop="22dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnOrganizerHub"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_quick_action_button"
                            android:drawableTop="@drawable/ic_nav_gift"
                            android:drawablePadding="9dp"
                            android:drawableTint="#000000"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minHeight="0dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:text="Rewards"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/btnNotificationsHub"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="30dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_quick_action_button"
                            android:drawableTop="@drawable/ic_action_request"
                            android:drawablePadding="9dp"
                            android:drawableTint="#000000"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:minHeight="0dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:text="Request Event"
                            android:textAllCaps="false"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutUpcomingEvents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/bg_card"
                    android:elevation="5dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Upcoming Events"
                            android:textColor="#000000"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtUpcomingEventsViewAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View All"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutRecentActivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="23dp"
                    android:background="@drawable/bg_card"
                    android:elevation="4dp"
                    android:minHeight="112dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="21dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Recent Activity"
                            android:textColor="#000000"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View All"
                            android:textColor="#000000"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtDashboardLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Loading dashboard..."
                    android:textColor="@color/eventqr_muted"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <TextView
        android:id="@+id/txtTotalTransactions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtTotalNotifications"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnRewardsHub"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnReportsHub"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="38dp">

        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="39dp"
                android:layout_height="39dp"
                android:background="@drawable/bg_nav_icon_active"
                android:contentDescription="Dashboard"
                android:padding="9dp"
                android:src="@drawable/ic_nav_home"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Dashboard"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navEvents"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="39dp"
                android:layout_height="39dp"
                android:background="@drawable/bg_nav_icon_inactive"
                android:contentDescription="Events"
                android:padding="8dp"
                android:src="@drawable/ic_nav_calendar"
                android:tint="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Events"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRewards"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="39dp"
                android:layout_height="39dp"
                android:background="@drawable/bg_nav_icon_inactive"
                android:contentDescription="Rewards"
                android:padding="8dp"
                android:src="@drawable/ic_nav_gift"
                android:tint="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Rewards"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="39dp"
                android:layout_height="39dp"
                android:background="@drawable/bg_nav_icon_inactive"
                android:contentDescription="Profile"
                android:padding="8dp"
                android:src="@drawable/ic_nav_profile"
                android:tint="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Profile"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
