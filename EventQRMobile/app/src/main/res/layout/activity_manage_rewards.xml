<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:background="#F3F4F6"
    android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Rewards" android:textColor="@color/black" android:textSize="26sp" android:textStyle="bold" />
        <Button android:id="@+id/btnLoadManageRewards" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/button_rounded" android:text="Refresh Rewards" android:textAllCaps="false" android:textColor="@color/white" />
        <EditText android:id="@+id/edtRewardsEventId" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/edittext_bg" android:hint="Event ID" android:padding="14dp" />
        <EditText android:id="@+id/edtRewardName" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/edittext_bg" android:hint="Reward name" android:padding="14dp" />
        <EditText android:id="@+id/edtRewardPointsRequired" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/edittext_bg" android:hint="Points required" android:inputType="number" android:padding="14dp" />
        <EditText android:id="@+id/edtRewardStock" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/edittext_bg" android:hint="Stock quantity" android:inputType="number" android:padding="14dp" />
        <Button android:id="@+id/btnCreateReward" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/button_rounded" android:text="Create Reward" android:textAllCaps="false" android:textColor="@color/white" />

        <EditText android:id="@+id/edtPointRuleScanPurposeId" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="16dp" android:background="@drawable/edittext_bg" android:hint="Scan purpose ID" android:padding="14dp" />
        <EditText android:id="@+id/edtPointRulePoints" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/edittext_bg" android:hint="Points" android:inputType="number" android:padding="14dp" />
        <CheckBox android:id="@+id/chkPointRuleActive" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Active" />
        <Button android:id="@+id/btnCreatePointRule" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="12dp" android:background="@drawable/button_rounded" android:text="Create Point Rule" android:textAllCaps="false" android:textColor="@color/white" />

        <TextView android:id="@+id/txtRewardsList" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:textColor="#4B5563" />
        <TextView android:id="@+id/txtPointRulesList" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:textColor="#4B5563" />
        <TextView android:id="@+id/txtRedemptionsList" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:textColor="#4B5563" />
    </LinearLayout>
</ScrollView>

    <include
        android:id="@+id/nav_view_container"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>