<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_eventqr_gradient">

        <Button
            android:id="@+id/btnBackToSignIn"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:background="@android:color/transparent"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="‹"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="42sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="49dp">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:contentDescription="EventQR logo"
                android:src="@drawable/white_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Forgot Password"
                android:textColor="#FFFFFF"
                android:textSize="31sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:gravity="center"
                android:text="Reset your password and regain access to your account"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="21dp"
            android:paddingTop="33dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textColor="#111111"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_outline_button"
                android:drawableStart="@drawable/email_icon"
                android:drawablePadding="10dp"
                android:hint="Enter email address"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="13dp"
                android:textColor="@color/eventqr_text"
                android:textColorHint="#6B7280"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnSendResetLink"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="19dp"
                android:background="@drawable/bg_primary_button"
                android:elevation="6dp"
                android:text="Send Reset Link"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
