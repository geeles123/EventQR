<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:id="@+id/layoutNotificationCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_notification_card_read"
        android:elevation="2dp"
        android:gravity="top"
        android:minHeight="96dp"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:id="@+id/layoutNotificationIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_notification_icon_box"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgNotificationIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_admin_notification"
                android:tint="#10B981" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNotificationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/eventqr_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNotificationMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#475467"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtNotificationDateTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#98A2B3"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:id="@+id/viewUnreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_notification_unread_dot"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>