<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scanner"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Manual QR input is enabled. Camera scanning is intentionally deferred for build safety."
            android:textColor="#4B5563" />

        <Spinner
            android:id="@+id/spnScannerEvent"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp" />

        <Spinner
            android:id="@+id/spnScannerPurpose"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtScannerQr"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/edittext_bg"
            android:hint="QR value"
            android:inputType="text"
            android:padding="14dp" />

        <EditText
            android:id="@+id/edtScannerNotes"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/edittext_bg"
            android:hint="Notes"
            android:inputType="textMultiLine"
            android:padding="14dp" />

        <Button
            android:id="@+id/btnSubmitScan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/button_rounded"
            android:text="Record Scan"
            android:textAllCaps="false"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/txtScannerResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/transparent_alt"
            android:padding="16dp"
            android:text="Each scan result appears here."
            android:textColor="#111827" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerScannerResults"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>