<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:text="Scan Purposes"
        android:textColor="@color/black"
        android:textSize="26sp"
        android:textStyle="bold" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp">

            <Button
                android:id="@+id/btnLoadScanPurposes"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_rounded"
                android:text="Refresh Purposes"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <EditText
                android:id="@+id/edtScanPurposeEventId"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Event ID"
                android:padding="14dp"
                android:singleLine="true" />

            <EditText
                android:id="@+id/edtScanPurposeName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:hint="Name"
                android:padding="14dp"
                android:singleLine="true" />

            <Spinner
                android:id="@+id/spnScanPurposeCode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:paddingHorizontal="14dp" />

            <CheckBox
                android:id="@+id/chkScanPurposeActive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Active" />

            <CheckBox
                android:id="@+id/chkScanPurposeTrackingOnly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tracking only" />

            <EditText
                android:id="@+id/edtScanPurposeDescription"
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edittext_bg"
                android:gravity="top|start"
                android:hint="Description"
                android:inputType="textMultiLine"
                android:padding="14dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnScanPurposeEntry"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:minWidth="92dp"
                        android:text="Entry"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnScanPurposeAttendance"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="112dp"
                        android:text="Attendance"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnScanPurposeBenefitClaim"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="92dp"
                        android:text="Benefit"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnScanPurposeBoothVisit"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="92dp"
                        android:text="Booth"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnScanPurposeSessionVisit"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="92dp"
                        android:text="Session"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnScanPurposeRewardRedemption"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="92dp"
                        android:text="Reward"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btnScanPurposeExit"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:minWidth="92dp"
                        android:text="Exit"
                        android:textAllCaps="false" />
                </LinearLayout>
            </HorizontalScrollView>

            <Button
                android:id="@+id/btnCreateScanPurpose"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_rounded"
                android:text="Create Scan Purpose"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerManageScanPurposes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="20dp" />
</LinearLayout>