<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_admin_surface_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="12dp">

    <View
        android:id="@+id/auditIconTile"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_admin_role_badge_green" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textAuditActionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Event Request Approved"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textAuditActorTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="By Admin User · Target: AI Workshop 2026"
            android:textColor="#4B5563"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textAuditTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="May 15, 11:00 AM"
            android:textColor="#6B7280"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
