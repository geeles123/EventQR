<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eventqr_bg"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/eventqr_card"
        android:paddingHorizontal="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="14dp"
        android:text="Audit Logs"
        android:textColor="#111827"
        android:textSize="20sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAuditAll"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_admin_filter_chip_active"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="All"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipAuditApproval"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_admin_filter_chip_inactive"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Approval"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipAuditAccount"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_admin_filter_chip_inactive"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Account"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipAuditSecurity"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_admin_filter_chip_inactive"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Security"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipAuditNotification"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_admin_filter_chip_inactive"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Notification"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/progressAuditLoading"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/textAuditPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Audit logs are not configured yet."
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAuditLogs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_nav_icon_inactive"
                android:padding="8dp"
                android:src="@drawable/ic_nav_home"
                android:tint="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Dashboard"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRequests"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_nav_icon_inactive"
                android:padding="8dp"
                android:src="@drawable/ic_action_request"
                android:tint="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Requests"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAccounts"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_nav_icon_inactive"
                android:padding="8dp"
                android:src="@drawable/ic_group"
                android:tint="#000000" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Accounts"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLogs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_nav_icon_active"
                android:padding="8dp"
                android:src="@drawable/ic_file"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Logs"
                android:textColor="#312E81"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
