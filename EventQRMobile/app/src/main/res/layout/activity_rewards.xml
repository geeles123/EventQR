<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/eventqr_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_eventqr_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="30dp"
        android:paddingBottom="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rewards"
            android:textColor="@color/eventqr_card"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtRewardsBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Points: 0"
            android:textColor="#E5E7EB"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtRewardsLoading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Loading rewards..."
            android:textColor="#E5E7EB"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="18dp">

        <EditText
            android:id="@+id/edtRewardsEventId"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input"
            android:hint="Select event"
            android:paddingHorizontal="16dp"
            android:textColor="@color/eventqr_text"
            android:textColorHint="@color/eventqr_muted" />

        <Button
            android:id="@+id/btnLoadRewards"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_primary_button"
            android:text="Load Rewards"
            android:textAllCaps="false"
            android:textColor="@color/eventqr_card"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_reward_points"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Points Summary"
                android:textColor="#DDD6FE"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Available rewards for your selected event"
                android:textColor="@color/eventqr_card"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Available Rewards"
                android:textColor="@color/eventqr_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="View Claimed"
                android:textColor="@color/eventqr_indigo"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtRewardsEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="No rewards configured for this event yet."
            android:textColor="@color/eventqr_muted" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerRewards"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="10dp" />
    </LinearLayout>

    <include
        android:id="@+id/nav_view_container"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
