<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="20dp"
    android:background="@drawable/bg_card"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="18dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/txtAttendeeEventTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="30dp"
            android:textColor="#000000"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAttendeeEventMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:text="⋮"
            android:textColor="#6B7280"
            android:textSize="28sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/txtAttendeeEventStatus"
        android:layout_width="110dp"
        android:layout_height="30dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_soft_gray_pill"
        android:gravity="center"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtAttendeeEventDateTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:textColor="#6B7280"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/txtAttendeeEventLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:textColor="#6B7280"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/txtAttendeeEventRewards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="♧  Rewards available"
        android:textColor="#6B7280"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>
