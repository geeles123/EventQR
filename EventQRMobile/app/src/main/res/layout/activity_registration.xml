<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_eventqr_gradient"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="49dp">

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:contentDescription="EventQR logo"
            android:src="@drawable/white_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:text="Sign Up"
            android:textColor="#FFFFFF"
            android:textSize="31sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:gravity="center"
            android:text="Create your account and simplify event check-ins"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="31dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First Name"
                        android:textColor="#111111"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="49dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_auth_field"
                        android:hint="Darell"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="13dp"
                        android:textColor="@color/eventqr_text"
                        android:textColorHint="#71717A"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Name"
                        android:textColor="#111111"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/edtLastName"
                        android:layout_width="match_parent"
                        android:layout_height="49dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_auth_field"
                        android:hint="Melliza"
                        android:inputType="textPersonName"
                        android:paddingHorizontal="13dp"
                        android:textColor="@color/eventqr_text"
                        android:textColorHint="#71717A"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="Email Address"
                android:textColor="#111111"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtEmail"
                android:layout_width="match_parent"
                android:layout_height="49dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_auth_field"
                android:drawableStart="@drawable/email_icon"
                android:drawablePadding="10dp"
                android:hint="darelldave@gmail.com"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="13dp"
                android:textColor="@color/eventqr_text"
                android:textColorHint="#71717A"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Phone Number"
                android:textColor="#111111"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtPhoneNumber"
                android:layout_width="match_parent"
                android:layout_height="49dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_auth_field"
                android:drawableStart="@drawable/phone_icon"
                android:drawablePadding="10dp"
                android:hint="+63 123 456 897"
                android:inputType="phone"
                android:paddingHorizontal="13dp"
                android:textColor="@color/eventqr_text"
                android:textColorHint="#71717A"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Password"
                android:textColor="#111111"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="49dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_auth_field"
                android:drawableStart="@drawable/password_icon"
                android:drawableEnd="@drawable/ic_visibility_on"
                android:drawablePadding="10dp"
                android:hint="**********"
                android:inputType="textPassword"
                android:paddingHorizontal="13dp"
                android:textColor="@color/eventqr_text"
                android:textColorHint="#71717A"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/layoutPasswordRequirements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_password_requirements"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/viewStrength1"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="1"
                        android:background="@color/eventqr_border" />

                    <View
                        android:id="@+id/viewStrength2"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@color/eventqr_border" />

                    <View
                        android:id="@+id/viewStrength3"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@color/eventqr_border" />

                    <View
                        android:id="@+id/viewStrength4"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@color/eventqr_border" />
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/txtPasswordLengthRequirement"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="○ At least 8 characters"
                            android:textColor="@color/eventqr_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtPasswordCapitalRequirement"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="○ One uppercase letter"
                            android:textColor="@color/eventqr_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtPasswordNumberRequirement"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="○ One number"
                            android:textColor="@color/eventqr_muted"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtPasswordSpecialRequirement"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="○ One special character"
                            android:textColor="@color/eventqr_muted"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtPasswordStrength"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:textColor="@color/eventqr_muted"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </RelativeLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Confirm Password"
                android:textColor="#111111"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="49dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_auth_field"
                android:drawableStart="@drawable/password_icon"
                android:drawableEnd="@drawable/ic_visibility_on"
                android:drawablePadding="10dp"
                android:hint="**********"
                android:inputType="textPassword"
                android:paddingHorizontal="13dp"
                android:textColor="@color/eventqr_text"
                android:textColorHint="#71717A"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="49dp"
                android:layout_marginTop="19dp"
                android:background="@drawable/bg_primary_button"
                android:elevation="6dp"
                android:text="Create Account"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/btnSignIn"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign In"
                    android:textColor="@color/eventqr_indigo"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
